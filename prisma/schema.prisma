generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NewsStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

model NewsArticle {
  id          Int        @id @default(autoincrement())
  tag         String
  title       String
  shortDesc   String
  fullText    String     @db.Text
  imgUrl      String?
  publishedAt DateTime   @default(now())
  publishAt   DateTime?
  status      NewsStatus @default(DRAFT)
}

model ServiceDocument {
  id          Int     @id @default(autoincrement())
  docId       String  @unique
  title       String
  fileSize    String
  description String
  filePath    String  @default("")
  active      Boolean @default(true)
}

model NetworkAlert {
  id          Int         @id @default(autoincrement())
  type        AlertType   @default(SCHEDULED)
  zone        String
  title       String
  date        String
  duration    String
  description String
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
}

model AdminUser {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  hashedPassword String
  role           String   @default("editor")
  createdAt      DateTime @default(now())
}

enum AlertType {
  URGENT
  SCHEDULED
  RESOLVED
}

model AvariaReport {
  id          Int      @id @default(autoincrement())
  type        String
  lat         Float
  lng         Float
  description String
  reporterIp  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String?
  mensagem  String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MediaAsset {
  id           Int      @id @default(autoincrement())
  filename     String   @unique
  originalName String
  url          String   @unique
  mimeType     String
  sizeBytes    Int
  uploadedBy   String?
  createdAt    DateTime @default(now())
}

model PublicUser {
  id             Int             @id @default(autoincrement())
  nome           String
  email          String          @unique
  hashedPassword String
  telefone       String?
  nrContador     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  lastLoginAt    DateTime?
  sessions       PublicSession[]
}

model PublicSession {
  id        String     @id @default(cuid())
  userId    Int
  user      PublicUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime   @default(now())
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id         String      @id @default(cuid())
  orderRef   String      @unique
  nome       String
  email      String
  phone      String
  items      Json
  total      Float
  status     OrderStatus @default(PENDING)
  paymentRef String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

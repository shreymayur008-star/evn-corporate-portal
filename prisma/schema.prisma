generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model NewsArticle {
  id          Int      @id @default(autoincrement())
  tag         String
  title       String
  shortDesc   String
  fullText    String   @db.Text
  imgUrl      String
  publishedAt DateTime @default(now())
  active      Boolean  @default(true)
}

model ServiceDocument {
  id          Int     @id @default(autoincrement())
  docId       String  @unique
  title       String
  fileSize    String
  description String
  filePath    String  @default("")
  active      Boolean @default(true)
}

model NetworkAlert {
  id          Int         @id @default(autoincrement())
  type        AlertType   @default(SCHEDULED)
  zone        String
  title       String
  date        String
  duration    String
  description String
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
}

model AdminUser {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  hashedPassword String
  role           String   @default("editor")
  createdAt      DateTime @default(now())
}

enum AlertType {
  URGENT
  SCHEDULED
  RESOLVED
}

model AvariaReport {
  id          Int      @id @default(autoincrement())
  type        String
  lat         Float
  lng         Float
  description String
  reporterIp  String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String
  mensagem  String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
